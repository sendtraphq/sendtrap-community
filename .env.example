APP_NAME="Sendtrap Community"
# For production deployments set APP_ENV=production and APP_DEBUG=false.
APP_ENV=local
# Generated by `php artisan key:generate` during install — leave empty here.
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=sendtrap
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Live inbox updates. The UI's Echo client is
# constructed lazily (@sendtrap/core useEcho.js): with no VITE_REVERB_APP_KEY
# it degrades to "no live updates" instead of erroring, so `log` is a safe
# offline default. To enable live updates: composer require laravel/reverb,
# php artisan reverb:install, set BROADCAST_CONNECTION=reverb + the REVERB_*
# keys it writes (VITE_REVERB_APP_KEY/HOST/PORT/SCHEME mirror them for the
# browser), run php artisan reverb:start, and rebuild assets.
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Incoming SMTP mail is parsed by the ProcessIncomingMessage queue job. `sync`
# runs it inline in the SMTP daemon so captured mail appears immediately with
# no separate worker process — the right default for a single-node sandbox.
# For high ingest volume (or a production install), switch to a real queue
# (database/redis) and run `php artisan queue:work` plus the scheduler under a
# process supervisor; see the README "production" notes.
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# S3-compatible message/attachment storage.
# Optional: raw .eml + attachments live on the `local` disk by default.
# To opt in, fill the AWS_* keys (any S3-compatible endpoint works), then
# either set FILESYSTEM_DISK=s3 for new mail or run
# `php artisan storage:migrate-to-s3` to move existing files across
# (it needs both the `local` and `s3` disks configured, which they are
# in config/filesystems.php).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# SMTP ingestion server (php artisan mail:smtp-server, config/sendtrap.php).
# Defaults shown; the catcher listens on all interfaces, port 1025. This is
# the server your application SENDS mail to — not outbound mail credentials.
# SENDTRAP_SMTP_BIND=0.0.0.0
# SENDTRAP_SMTP_PORT=1025
# Optional install-time IP allowlist for SMTP clients (comma-separated CIDRs
# or addresses), applied to the workspace by `php artisan sendtrap:install`.
# SENDTRAP_INSTANCE_ALLOWED_IPS=

# Spam analysis (sendtrap/core host requirement, config/services.php).
# Disabled by default — Community is offline-first; the Spam tab shows
# a "not configured" state instead of an error when this is off.
SPAMCHECK_ENABLED=false
SPAMCHECK_URL=
SPAMCHECK_TIMEOUT=5
SPAMCHECK_THRESHOLD=5.0

# Instance limits (config/sendtrap-community.php — see the LIMIT SEMANTICS
# comment block there for the full explanation). All commented out
# below = unset = UNLIMITED. Uncommenting a var with a value of 0 BLOCKS
# that limit entirely (e.g. SENDTRAP_FORWARDS_PER_MONTH=0 turns forwarding
# off) — 0 is never "unlimited" here.
# SENDTRAP_SENDS_PER_MINUTE=
# SENDTRAP_SENDS_PER_MONTH=
# SENDTRAP_FORWARDS_PER_MONTH=
# SENDTRAP_EMAIL_SIZE_BYTES=
# SENDTRAP_PROJECTS_LIMIT=
# SENDTRAP_INBOXES_LIMIT=
# SENDTRAP_USERS_LIMIT=
# SENDTRAP_MESSAGES_PER_INBOX=
# SENDTRAP_RETENTION_DAYS=
# SENDTRAP_STORAGE_BYTES=
# SENDTRAP_API_REQUESTS_PER_MINUTE=

VITE_APP_NAME="${APP_NAME}"
