# Sendtrap Community — container environment template (Plan 06 Phase 7 §6).
#
# Copy to `.env` next to docker-compose.yml and edit. docker compose reads it
# automatically. Only APP_URL + the three SENDTRAP_ADMIN_* values are required
# on a first run; everything else has a safe default.

# ---------------------------------------------------------------------------
# Identity / exposure
# ---------------------------------------------------------------------------
# Public URL. Drives absolute links + share URLs. Use https:// when behind a
# TLS proxy (the image trusts X-Forwarded-* by default).
APP_URL=https://mail.example.com

# APP_KEY — LEAVE UNSET to auto-generate + persist to /data/app.key on first
# boot. If you set it, keep it FOREVER: it decrypts every inbox's smtp_password
# and signs sessions. A changed/lost key = smtp_password + sessions unusable
# (message bodies, api_token, webhook_secret survive). The container refuses to
# start if a supplied APP_KEY disagrees with the key that encrypted /data.
# APP_KEY=

# ---------------------------------------------------------------------------
# First-run owner + workspace (§4.2) — required on a fresh volume.
# ---------------------------------------------------------------------------
SENDTRAP_ADMIN_NAME=Admin
SENDTRAP_ADMIN_EMAIL=admin@example.com
# Deliver as a secret in production; unused after the owner exists.
SENDTRAP_ADMIN_PASSWORD=change-me-now
SENDTRAP_WORKSPACE_NAME=Sendtrap

# ---------------------------------------------------------------------------
# SMTP ingestion (config/sendtrap.php). The daemon binds 0.0.0.0:1025 inside
# the container; the host mapping is in docker-compose.yml.
# ---------------------------------------------------------------------------
# What the UI tells users to point their app's MAIL_HOST/PORT at:
SENDTRAP_PUBLIC_HOST=mail.example.com
# SENDTRAP_PUBLIC_PORTS=1025,2525,587
# SENDTRAP_SMTP_PORT=1025
# STARTTLS is ON by default; a self-signed cert is auto-generated to the volume.
# SENDTRAP_TLS=true
# SENDTRAP_REQUIRE_TLS=false
# Bring-your-own cert (else self-signed):
# SENDTRAP_TLS_CERT=/data/storage/app/sendtrap-tls/cert.pem
# SENDTRAP_TLS_KEY=/data/storage/app/sendtrap-tls/key.pem
# Abuse/DoS limits (defaults shown in config/sendtrap.php):
# SENDTRAP_MAX_CONNECTIONS=200
# SENDTRAP_MAX_CONNECTIONS_PER_IP=10
# SENDTRAP_IDLE_TIMEOUT=60
# SENDTRAP_MAX_RECIPIENTS=100
# Install-time SMTP client allowlist (comma-separated CIDRs/addresses). STRONGLY
# recommended if port 1025 is reachable from an untrusted network (§9).
# SENDTRAP_INSTANCE_ALLOWED_IPS=

# ---------------------------------------------------------------------------
# Instance limits (config/sendtrap-community.php). LIMIT SEMANTICS (D-17):
# UNSET / absent = UNLIMITED. A value of 0 = BLOCKED (e.g.
# SENDTRAP_FORWARDS_PER_MONTH=0 turns forwarding off). 0 is NEVER "unlimited".
# ---------------------------------------------------------------------------
# SENDTRAP_SENDS_PER_MINUTE=
# SENDTRAP_SENDS_PER_MONTH=
# SENDTRAP_FORWARDS_PER_MONTH=
# SENDTRAP_EMAIL_SIZE_BYTES=
# SENDTRAP_PROJECTS_LIMIT=
# SENDTRAP_INBOXES_LIMIT=
# SENDTRAP_USERS_LIMIT=
# SENDTRAP_MESSAGES_PER_INBOX=
# SENDTRAP_RETENTION_DAYS=
# SENDTRAP_STORAGE_BYTES=
# SENDTRAP_API_REQUESTS_PER_MINUTE=

# ---------------------------------------------------------------------------
# Storage / backends (§3.3). Defaults are self-contained (SQLite + local disk
# on the /data volume). Override for "grown-up" backends — no image rebuild;
# pdo_mysql/pdo_pgsql/redis are compiled in.
# ---------------------------------------------------------------------------
# DB_CONNECTION=mysql
# DB_HOST=db
# DB_PORT=3306
# DB_DATABASE=sendtrap
# DB_USERNAME=sendtrap
# DB_PASSWORD=sendtrap
#
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# REDIS_HOST=redis
# REDIS_PORT=6379
#
# S3-compatible message/attachment storage:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------------------
# Optional features
# ---------------------------------------------------------------------------
# Spam analysis — off by default (offline-first).
# SPAMCHECK_ENABLED=false
# SPAMCHECK_URL=
# SPAMCHECK_TIMEOUT=5
# SPAMCHECK_THRESHOLD=5.0
#
# Extra queue workers (default 1).
# SENDTRAP_QUEUE_WORKERS=1
#
# Live inbox updates via Reverb are a published image VARIANT (VITE_* keys are
# compiled into the browser bundle at asset-build), NOT a runtime toggle here.
# The default image is Reverb-free and fully functional (polling ?wait=).
